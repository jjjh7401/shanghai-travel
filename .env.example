# Baidu Maps(百度地图) API 설정
# https://lbsyun.baidu.com/ 에서 발급 (한국 번호로 가입 가능)
NEXT_PUBLIC_BAIDU_MAP_KEY=your_baidu_map_ak_here

# Amap(高德地图) API 설정 (레거시, 미사용)
# NEXT_PUBLIC_AMAP_KEY=your_amap_api_key_here
# NEXT_PUBLIC_AMAP_SECURITY_CODE=your_amap_security_code_here

# 환율 API (선택사항)
# https://www.exchangerate-api.com/ 무료 티어 사용 가능
NEXT_PUBLIC_EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
